# ============================================
# Universal Order System - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values

# Firebase Client SDK
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase Admin SDK (for server-side)
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=your_service_account_email
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key\n-----END PRIVATE KEY-----\n"

# Stripe (optional - remove if not using card payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# PromptPay / QR Payments (optional)
NEXT_PUBLIC_PROMPTPAY_ENABLED=false
NEXT_PUBLIC_PROMPTPAY_ID=your_promptpay_id_here

# LINE Notifications (optional)
LINE_CHANNEL_ACCESS_TOKEN=your_line_token_here
LINE_ADMIN_USER_ID=your_line_user_id_here

# SMS Notifications (optional - Twilio example)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Shop Configuration
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SHOP_NAME=My Shop
NEXT_PUBLIC_SHOP_PHONE=+1-555-0123
NEXT_PUBLIC_SHOP_DESCRIPTION=Order delicious food & drinks online
NEXT_PUBLIC_SHOP_TAGLINE=Fresh & Delicious
NEXT_PUBLIC_CURRENCY=USD
NEXT_PUBLIC_CURRENCY_SYMBOL=$
NEXT_PUBLIC_LOCALE=en-US
NEXT_PUBLIC_SECONDARY_LOCALE=
NEXT_PUBLIC_CURRENCY_MULTIPLIER=100
